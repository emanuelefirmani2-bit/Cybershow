# Server
PORT=3000
NODE_ENV=development

# Authentication
# Secret key for Regia access (change before every event)
EVENT_SECRET_KEY=SHOW-EXAMPLE-KEY
JWT_SECRET=your-super-secret-jwt-key-change-this

# Database
DB_PATH=./quiz.db

# MIDI (macOS only — graceful degradation on other platforms)
MIDI_ENABLED=true
MIDI_PORT_NAME=IAC Driver Bus 1

# Cloudflare Tunnel (set your tunnel URL here)
PUBLIC_URL=https://cybershow.example.com

# QR Code URL shown on Ledwall (set to your LAN IP or tunnel URL)
# Example: http://192.168.1.50:5274 or https://cybershow.example.com
VITE_PUBLIC_URL=
